# =========================================================
#  КонтрактСВО — серверная конфигурация (Apache)
#  Безопасность, кэширование, редирект на HTTPS
# =========================================================

# Запрет просмотра содержимого каталогов
Options -Indexes

# --- Редирект на HTTPS ---
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Закрываем служебные/приватные пути
  RewriteRule ^tools/ - [F,L]
  RewriteRule ^\.git/ - [F,L]
</IfModule>

# --- Заголовки безопасности ---
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  # CRM Bitrix24: разрешаем fetch к вебхуку в connect-src
  Header always set Content-Security-Policy "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self'; connect-src 'self' https://b24-fbicjs.bitrix24.ru; frame-src 'self' https://yandex.ru; frame-ancestors 'self'; base-uri 'self'"
</IfModule>

# --- Кэширование статики ---
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/jpeg "access plus 6 months"
  ExpiresByType image/png "access plus 6 months"
  ExpiresByType image/svg+xml "access plus 6 months"
</IfModule>

# --- Сжатие ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml
</IfModule>
